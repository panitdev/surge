{
  "name": "@panit/surge-client",
  "version": "0.1.1",
  "description": "Browser client for the Surge authentication API (login flows, sessions).",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": false,
  "keywords": [
    "surge",
    "auth",
    "authentication",
    "session",
    "browser"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/panitdev/surge",
    "directory": "packages/surge-client"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "devDependencies": {
    "@types/bun": "^1",
    "typescript": "^5"
  }
}
